# ============================================================
# APPLICATION
# ============================================================
# Execution environment. Values: development | test | production
NODE_ENV=development

# Port the API server listens on
PORT=3000

# Full URL where the API is accessible (used for CORS and links)
API_URL=http://localhost:3000

# Full URL where the web app is accessible
CLIENT_URL=http://localhost:5173

# API version prefix
API_VERSION=v1

# ============================================================
# DATABASE
# ============================================================
# PostgreSQL user
POSTGRES_USER=erp_user

# PostgreSQL password
POSTGRES_PASSWORD=erp_password

# PostgreSQL database name
POSTGRES_DB=erp_db

# Full PostgreSQL connection string
DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/erp_db?schema=public

# Connection pool: minimum connections per Prisma client instance
DATABASE_POOL_MIN=2

# Connection pool: maximum connections per Prisma client instance
DATABASE_POOL_MAX=10

# ============================================================
# REDIS
# ============================================================
# Redis server hostname
REDIS_HOST=localhost

# Redis server port
REDIS_PORT=6379

# Redis password (leave empty if no password)
REDIS_PASSWORD=

# Redis DB index for sessions/cache (0-15)
REDIS_DB=0

# Redis DB index for BullMQ jobs (separate DB from cache)
REDIS_QUEUE_DB=1

# ============================================================
# JWT AUTHENTICATION
# ============================================================
# Access token secret key (min 32 characters)
JWT_ACCESS_SECRET=your-super-secret-access-key-min-64-chars-long-change-this-in-production

# Refresh token secret key (min 32 characters)
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-64-chars-long-change-this-in-production

# Access token expiry (short-lived)
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token expiry
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# RATE LIMITING
# ============================================================
# Window in milliseconds (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window per IP
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# LOGGING
# ============================================================
# Winston log level. Values: error | warn | info | http | debug
LOG_LEVEL=debug

# Pretty print logs in development
LOG_PRETTY=true

# ============================================================
# CORS
# ============================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================
# PGADMIN (Docker only)
# ============================================================
# pgAdmin login email
PGADMIN_DEFAULT_EMAIL=admin@erp.local

# pgAdmin login password
PGADMIN_DEFAULT_PASSWORD=admin123
