# ============================================================
# TEST ENVIRONMENT
# ============================================================
NODE_ENV=test
PORT=3001
API_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173
API_VERSION=v1

# ============================================================
# DATABASE (Test)
# ============================================================
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password
POSTGRES_DB=erp_test
DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/erp_test?schema=public
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=5

# ============================================================
# REDIS (Test)
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=2
REDIS_QUEUE_DB=3

# ============================================================
# JWT (Test)
# ============================================================
JWT_ACCESS_SECRET=test-access-secret-key-that-is-at-least-32-characters-long-for-testing
JWT_REFRESH_SECRET=test-refresh-secret-key-that-is-at-least-32-characters-long-for-testing
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# RATE LIMITING (Test - relaxed)
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ============================================================
# LOGGING (Test - minimal)
# ============================================================
LOG_LEVEL=error
LOG_PRETTY=false

# ============================================================
# CORS (Test)
# ============================================================
CORS_ORIGINS=http://localhost:3001,http://localhost:5173
